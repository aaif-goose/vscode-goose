# Ignore everything by default
**/*

# --- Explicitly INCLUDE ---
# Extension bundle (generated by bun build)
!dist/extension.js
!dist/extension.js.map
# Webview UI build output
!dist/webview/**
# Static resources (icons, etc.)
!resources/**
# Essential package metadata files
!package.json
!README.md
!CHANGELOG.md
!LICENSE

# --- Explicitly EXCLUDE (even if covered by **/* above, for clarity/safety) ---
# Source code (bundled into dist/)
src/**

# Node modules (dependencies are bundled)
node_modules/**

# Build, config, and tooling files
**/tsconfig.json
**/biome.json
.editorconfig

# VS Code specific development/test files
.vscode/**
.vscode-test/**
**/.vscode-test.*

# Test files/folders (not needed in packaged extension)
**/*.test.ts
**/test/**
**/tests/**
**/__tests__/**
**/__mocks__/**
**/coverage/**

# Git / OS / Editor specific files
.git/**
.github/**
.husky/**
**/.DS_Store
**/.idea/**

# Other development/project files
.gitignore
.npmrc
.rp1/**
docs/**

# Log files
**/*.log

# Packaged extension files (avoid nesting/including previous builds)
**/*.vsix

# Lock files
bun.lock
package-lock.json
